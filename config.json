  "windows_settings": {
    "explorer": {
      "show_file_extensions": true,
      "show_hidden_files": true,
      "show_full_path_in_title": true,
      "open_to_this_pc": true,
      "disable_recent_files_in_quick_access": false
    },
    "taskbar": {
      "hide_search_box": false,
      "hide_task_view_button": false,
      "hide_widgets": true,
      "hide_chat": true,
      "small_taskbar_icons": false
    },
    "system": {
      "dark_mode": true,
      "disable_startup_delay": true,
      "enable_developer_mode": true,
      "disable_bing_search_in_start_menu": true,
      "set_power_plan_high_performance": true
    },
    "privacy": {
      "disable_telemetry": true,
      "disable_activity_history": true,
      "disable_advertising_id": true
    }
  },
